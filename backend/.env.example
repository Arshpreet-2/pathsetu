# ============================================================
# .env.example — TEMPLATE FILE
# ============================================================
# Copy this file to a new file named ".env" (without ".example")
# Then replace the placeholder with your real Gemini API key.
#
# The real .env file is git-ignored — it stays on your computer
# and never goes to GitHub. Same key gets pasted into Render's
# Environment Variables panel during deployment.
# ============================================================

GEMINI_API_KEY=AIzaSy-PASTE-YOUR-REAL-KEY-HERE

# Optional: which Gemini model to use (default works fine)
GEMINI_MODEL=gemini-2.5-flash

# Optional: port for local dev (Render sets this automatically in production)
PORT=8000
